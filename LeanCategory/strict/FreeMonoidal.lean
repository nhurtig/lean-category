import Mathlib

/- Given a quiver over a monoid, construct the free monoidal category
generated by that quiver -/

variable {V : Type u} [Monoid V] [Quiver.{v} V]

postfix:max "⋆" => Star.star

class StarMonoid (R : Type u) [Monoid R] extends InvolutiveStar R where
  /-- `star` skew-distributes over multiplication. -/
  star_mul : ∀ r s : R, (r * s)⋆ = s⋆ * r⋆

inductive Hom : V → V → Type max u v
  | of : (X ⟶ Y) → Hom X Y -- from the quiver
  | id : (X : V) → Hom X X
  | comp {X Y Z} (f : Hom X Y) (g : Hom Y Z) : Hom X Z
  | tensor {W X Y Z} (f : Hom W Y) (g : Hom X Z) : Hom (W * X) (Y * Z)

open CategoryTheory

-- def StrictMonoidalProduct (X : Type u) := X

notation "S " => id

-- gives us notation
instance : Monoid (S V) where
  one := (1 : V)
  mul (X Y : V) := (X * Y : V)
  mul_assoc (A B C : V) := mul_assoc A B C
  one_mul (A : V) := one_mul A
  mul_one (A : V) := mul_one A

-- gives us notation
instance : CategoryStruct (S V) where
  Hom (X Y : V) := Hom X Y
  id (X : V) := Hom.id X
  comp := Hom.comp

-- synonym for Hom.Tensor that acts on the CategoryStruct notation
def myTensor {W X Y Z : S V} (f : W ⟶ Y) (g : X ⟶ Z) : (W * X) ⟶ (Y * Z) := Hom.tensor f g
infixr:70 " ⊗ " => myTensor

-- synonyms to make the monoidal category instance happy (IDK why Mathlib does it this way)
@[simp, grind]
def Hom.whiskerLeft (X : S V) {Y₁ Y₂ : S V} (f : Y₁ ⟶ Y₂) : (X * Y₁) ⟶ (X * Y₂) :=
  (𝟙 X) ⊗ f

@[simp, grind]
def Hom.whiskerRight {X₁ X₂ : S V} (f : X₁ ⟶ X₂) (Y : S V) : (X₁ * Y) ⟶ (X₂ * Y) :=
  f ⊗ (𝟙 Y)

infixr:81 " ◁ " => Hom.whiskerLeft
infixl:81 " ▷ " => Hom.whiskerRight

@[grind]
inductive HomEquiv : ∀ {A B : S V}, (A ⟶ B) → (A ⟶ B) → Prop
  | refl (f : X ⟶ Y) : HomEquiv f f
  | comp {f f' : X ⟶ Y} {g g' : Y ⟶ Z} :
      HomEquiv f f' → HomEquiv g g' → HomEquiv (f ≫ g) (f' ≫ g')
  | tensor {f f' : W ⟶ X} {g g' : Y ⟶ Z} :
      HomEquiv f f' → HomEquiv g g' → HomEquiv (f ⊗ g) (f' ⊗ g')
  | comp_id (f : X ⟶ Y) : HomEquiv (f ≫ (𝟙 _)) f
  | id_comp (f : X ⟶ Y) : HomEquiv ((𝟙 _ ) ≫ f) f
  | assoc (f : W ⟶ X) (g : X ⟶ Y) (h : Y ⟶ Z) :
      HomEquiv ((f ≫ g) ≫ h) (f ≫ (g ≫ h))
  | id_tensor_id {X Y : S V} : HomEquiv ((𝟙 X) ⊗ (𝟙 Y)) (𝟙 _)
  | tensor_comp_tensor (f₁ : X₁ ⟶ Y₁) (f₂ : X₂ ⟶ Y₂)
      (g₁ : Y₁ ⟶ Z₁) (g₂ : Y₂ ⟶ Z₂) :
    HomEquiv ((f₁ ⊗ f₂) ≫ (g₁ ⊗ g₂)) ((f₁ ≫ g₁) ⊗ (f₂ ≫ g₂))
  -- replacing the associator and unitors
  | tensor_assoc (f : P ⟶ Q) (g : W ⟶ X) (h : Y ⟶ Z) :
      HomEquiv (((f ⊗ g) ⊗ h) ≫ (eqToHom (mul_assoc Q X Z))) ((eqToHom (mul_assoc P W Y)) ≫ (f ⊗ (g ⊗ h)))
  | id_tensor (f : X ⟶ Y) : HomEquiv (((𝟙 1) ⊗ f) ≫ (eqToHom (one_mul Y))) ((eqToHom (one_mul X)) ≫ f)
  -- | id_tensor (f : X ⟶ Y) : HomEquiv ((𝟙 1) ⊗ f) f
  | tensor_id (f : X ⟶ Y) : HomEquiv ((f ⊗ (𝟙 1)) ≫ (eqToHom (mul_one Y))) ((eqToHom (mul_one X)) ≫ f)
  | symm (f g : X ⟶ Y) : HomEquiv f g → HomEquiv g f
  | trans {f g h : X ⟶ Y} : HomEquiv f g → HomEquiv g h → HomEquiv f h

