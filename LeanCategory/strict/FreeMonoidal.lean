@[grind =_]
lemma HomEquiv.equiv_def {X Y : S V} {f g : X ⟶ Y} : HomEquiv f g ↔ f ≈ g := by
  constructor
  all_goals intros h
  all_goals exact h

@[simp, grind .]
lemma eqToHom_comp {X Y Z : S V} {p : X = Y} {q : Y = Z} : (eqToHom p ≫ eqToHom q) ≈ (eqToHom (p.trans q)) := by
  cases p
  cases q
  simp
  grind
  -- apply HomEquiv.comp_id
