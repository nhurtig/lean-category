@[simp, grind .]
lemma eqToHom_tensor {W X Y Z : S V} {p : W = X} {q : Y = Z} : (eqToHom p ⊗ eqToHom q) ≈ (eqToHom (by simp [p, q])) := by
  cases p
  cases q
  simp
  grind
