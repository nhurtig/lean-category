instance setoidHom (X Y : S V) : Setoid (X ⟶ Y) :=
⟨HomEquiv, ⟨HomEquiv.refl, HomEquiv.symm _ _, HomEquiv.trans⟩⟩

def myHom (X Y : S V) := Quotient (setoidHom X Y)

@[grind =_]
lemma myHom_eq {X Y : S V} (f g : X ⟶ Y) : HomEquiv f g ↔ f ≈ g := by
  constructor
  all_goals intros h
  all_goals exact h

