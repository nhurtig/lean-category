import Mathlib
import LeanCategory.Egger
import LeanCategory.StarMonoid

/- Given a quiver over a monoid, construct the free twisted involutive monoidal category
generated by that quiver -/

variable {V : Type u}

variable [StarMonoid V]
variable [userQuiver : Quiver.{v} V]

inductive Hom : V Рєњ V Рєњ Type max u v
  | of : (X РЪХ Y) Рєњ Hom X Y -- from the quiver
  | id : (X : V) Рєњ Hom X X
  | comp {X Y Z} (f : Hom X Y) (g : Hom Y Z) : Hom X Z
  | tensor {W X Y Z} (f : Hom W Y) (g : Hom X Z) : Hom (W * X) (Y * Z)
  | star {X Y} (f : Hom X Y) : Hom XРІє YРІє
  | twist_hom (X : V) : Hom X XРІє
  | twist_inv (X : V) : Hom XРІє X

open CategoryTheory

instance prehom : CategoryStruct V where
  Hom := Hom
  id := Hom.id
  comp := Hom.comp

infixr:10 " РЪХрхЦ  " => prehom.Hom
notation "­ЮЪЎрхЦ" => prehom.id
infixr:80 " РЅФрхЦ " => prehom.comp

-- synonym for Hom.Tensor that acts on the CategoryStruct notation
abbrev myTensor {W X Y Z : V} (f : W РЪХрхЦ Y) (g : X РЪХрхЦ Z) : (W * X) РЪХрхЦ  (Y * Z) := Hom.tensor f g
infixr:70 " РіЌрхЦ " => myTensor

abbrev myStar {X Y : V} (f : X РЪХрхЦ Y) : XРІє РЪХрхЦ YРІє := Hom.star f
postfix:max "РІєрхЦ" => myStar

abbrev ¤ѓ_hom (X : V) := Hom.twist_hom X
abbrev ¤ѓ_inv (X : V) := Hom.twist_inv X

-- synonyms to make the monoidal category instance happy (IDK why Mathlib does it this way)
abbrev Hom.whiskerLeft (X : V) {YРѓЂ YРѓѓ : V} (f : YРѓЂ РЪХрхЦ YРѓѓ) : (X * YРѓЂ) РЪХрхЦ (X * YРѓѓ) :=
  (­ЮЪЎрхЦ X) РіЌрхЦ f

abbrev Hom.whiskerRight {XРѓЂ XРѓѓ : V} (f : XРѓЂ РЪХрхЦ XРѓѓ) (Y : V) : (XРѓЂ * Y) РЪХрхЦ (XРѓѓ * Y) :=
  f РіЌрхЦ (­ЮЪЎрхЦ Y)

infixr:81 " РЌЂрхЦ " => Hom.whiskerLeft
infixl:81 " РќирхЦ " => Hom.whiskerRight

@[grind]
inductive HomEquiv : Рѕђ {A B : V}, (A РЪХрхЦ B) Рєњ (A РЪХрхЦ B) Рєњ Prop
  | refl (f : X РЪХрхЦ  Y) : HomEquiv f f
  | assoc {W X Y Z : V} (f : W РЪХрхЦ X) (g : X РЪХрхЦ Y) (h : Y РЪХрхЦ Z) :
      HomEquiv ((f РЅФрхЦ g) РЅФрхЦ h) (f РЅФрхЦ (g РЅФрхЦ h))
  | comp_id (f : X РЪХрхЦ Y) : HomEquiv (f РЅФрхЦ (­ЮЪЎрхЦ _)) f
  | id_comp (f : X РЪХрхЦ Y) : HomEquiv ((­ЮЪЎрхЦ _) РЅФрхЦ f) f
  -- congruence
  | comp {f f' : X РЪХрхЦ Y} {g g' : Y РЪХрхЦ Z} :
      HomEquiv f f' Рєњ HomEquiv g g' Рєњ HomEquiv (f РЅФрхЦ g) (f' РЅФрхЦ g')
  | tensor {f f' : W РЪХрхЦ X} {g g' : Y РЪХрхЦ Z} :
      HomEquiv f f' Рєњ HomEquiv g g' Рєњ HomEquiv (f РіЌрхЦ g) (f' РіЌрхЦ g')
  | star {f f' : X РЪХрхЦ Y} :
      HomEquiv f f' Рєњ HomEquiv fРІєрхЦ f'РІєрхЦ
  -- (bi)functoriality
  | id_tensor_id {X Y : V} : HomEquiv ((­ЮЪЎрхЦ X) РіЌрхЦ (­ЮЪЎрхЦ Y)) (­ЮЪЎрхЦ _)
  | tensor_comp_tensor (fРѓЂ : XРѓЂ РЪХрхЦ YРѓЂ) (fРѓѓ : XРѓѓ РЪХрхЦ YРѓѓ)
      (gРѓЂ : YРѓЂ РЪХрхЦ ZРѓЂ) (gРѓѓ : YРѓѓ РЪХрхЦ ZРѓѓ) :
      HomEquiv ((fРѓЂ РіЌрхЦ fРѓѓ) РЅФрхЦ (gРѓЂ РіЌрхЦ gРѓѓ)) ((fРѓЂ РЅФрхЦ gРѓЂ) РіЌрхЦ (fРѓѓ РЅФрхЦ gРѓѓ))
  | star_id {X : V}: HomEquiv (­ЮЪЎрхЦ X)РІєрхЦ (­ЮЪЎрхЦ XРІє)
  | star_comp_star (f : X РЪХрхЦ Y) (g : Y РЪХрхЦ Z) :
      HomEquiv (f РЅФрхЦ g)РІєрхЦ (fРІєрхЦ РЅФрхЦ gРІєрхЦ)
  -- replacing the natural isomorphisms
  | tensor_assoc (f : P РЪХрхЦ Q) (g : W РЪХрхЦ X) (h : Y РЪХрхЦ Z) :
      HomEquiv (((f РіЌрхЦ g) РіЌрхЦ h) РЅФ (eqToHom (mul_assoc Q X Z)))
        ((eqToHom (mul_assoc P W Y)) РЅФрхЦ (f РіЌрхЦ(g РіЌрхЦ h)))
  | id_tensor (f : X РЪХрхЦ Y) :
      HomEquiv (((­ЮЪЎрхЦ 1) РіЌрхЦ f) РЅФрхЦ (eqToHom (one_mul Y))) ((eqToHom (one_mul X)) РЅФ f)
  | tensor_id (f : X РЪХрхЦ Y) :
      HomEquiv ((f РіЌрхЦ (­ЮЪЎрхЦ 1)) РЅФрхЦ (eqToHom (mul_one Y))) ((eqToHom (mul_one X)) РЅФ f)
  | star_skew (f : W РЪХрхЦ X) (g : Y РЪХрхЦ Z) :
      HomEquiv ((fРІєрхЦ РіЌрхЦ gРІєрхЦ) РЅФрхЦ (eqToHom (StarMul.star_mul Z X).symm))
        ((eqToHom (StarMul.star_mul Y W).symm) РЅФ (g РіЌрхЦ f)РІєрхЦ)
  | star_inv (f : X РЪХрхЦ Y) :
      HomEquiv (fРІєрхЦРІєрхЦ РЅФ (eqToHom (star_involutive Y))) ((eqToHom (star_involutive X)) РЅФрхЦ f)
  -- special facts about the twist
  | twist_hom_inv :
      HomEquiv ((¤ѓ_hom X) РЅФрхЦ (¤ѓ_inv X)) (­ЮЪЎрхЦ X)
  | twist_inv_hom :
      HomEquiv ((¤ѓ_inv X) РЅФрхЦ (¤ѓ_hom X)) (­ЮЪЎ XРІє)
  | twist_naturality (f : X РЪХрхЦ Y) :
      HomEquiv (fРІєрхЦ РЅФрхЦ (¤ѓ_inv Y)) ((¤ѓ_inv X) РЅФрхЦ f)
  | tРёЊ (P Q R : V) : HomEquiv
      ((((eqToHom (StarMul.star_mul QРІє PРІє).symm) РЅФ (¤ѓ_inv (QРІє * PРІє))) РіЌрхЦ (­ЮЪЎ RРІєРІє)) РЅФ
        (eqToHom (mul_assoc QРІє PРІє RРІєРІє)) РЅФ ((­ЮЪЎ QРІє) РіЌрхЦ ((eqToHom (StarMul.star_mul RРІє P).symm) РЅФ
        (¤ѓ_inv (RРІє * P)))) РЅФ (eqToHom (mul_assoc QРІє RРІє P).symm) РЅФ
        (((eqToHom (StarMul.star_mul R Q).symm) РЅФ (¤ѓ_inv (R * Q))) РіЌрхЦ (­ЮЪЎ P)) РЅФ
        (eqToHom (mul_assoc R Q P)))
      ((((¤ѓ_inv PРІє) РіЌрхЦ (¤ѓ_inv QРІє)) РіЌрхЦ (¤ѓ_inv RРІє)) РЅФ
        ((eqToHom (StarMul.star_mul Q P).symm) РіЌрхЦ (­ЮЪЎ RРІє)) РЅФ
        (eqToHom (StarMul.star_mul R (Q * P)).symm) РЅФ (¤ѓ_inv (R * (Q * P))))
  -- symm/trans last for constructor tactic
  | symm (f g : X РЪХрхЦ Y) : HomEquiv f g Рєњ HomEquiv g f
  | trans {f g h : X РЪХрхЦ Y} : HomEquiv f g Рєњ HomEquiv g h Рєњ HomEquiv f h

attribute [refl] HomEquiv.refl
attribute [symm] HomEquiv.symm

instance {A B : V} : HasEquiv (A РЪХрхЦ B) where
  Equiv := HomEquiv

-- helps grind slog through notation
@[grind =_]
lemma HomEquiv.equiv_def {X Y : V} {f g : X РЪХрхЦ Y} : HomEquiv f g Рєћ f РЅѕ g := by
  constructor
  all_goals intros h
  all_goals exact h

lemma eqToHom_comp {X Y Z : V} {f : X РЪХрхЦ Y} {g : Y РЪХрхЦ Z} {p : X = Y} {q : Y = Z} :
    (f РЅѕ eqToHom p) Рєњ (g РЅѕ eqToHom q) Рєњ (f РЅФрхЦ g) РЅѕ (eqToHom (p.trans q)) := by
  intros hf hg
  apply HomEquiv.trans
  ┬и exact HomEquiv.comp hf hg
  ┬и cases p
    cases q
    simp
    grind

lemma eqToHom_tensor {W X Y Z : V} {f : W РЪХрхЦ X} {g : Y РЪХрхЦ Z} {p : W = X} {q : Y = Z} :
    (f РЅѕ eqToHom p) Рєњ (g РЅѕ eqToHom q) Рєњ (f РіЌрхЦ g) РЅѕ (eqToHom (by simp [p, q])) := by
  intros hf hg
  apply HomEquiv.trans
  ┬и exact HomEquiv.tensor hf hg
  ┬и cases p
    cases q
    simp
    grind

lemma eqToHom_star {X Y : V} {f : X РЪХрхЦ Y} {p : X = Y} :
    (f РЅѕ eqToHom p) Рєњ fРІєрхЦ РЅѕ (eqToHom (by simp [p])) := by
  intros hf
  apply HomEquiv.trans
  ┬и exact HomEquiv.star hf
  cases p
  simp
  grind

-- Attempts to take one step of simplifying a bunch of eqToHom/id to one eqToHom
macro "reduce_eqToHom_step" : tactic =>
  `(tactic|
    first
      | apply eqToHom_comp
      | apply eqToHom_tensor
      | apply eqToHom_star
      | rfl
  )

-- shows any combination of eqToHom/id is HomEquiv to a single eqToHom
macro "reduce_eqToHom" : tactic =>
  `(tactic|
    repeat' reduce_eqToHom_step
  )

-- shows any combinations of eqToHom/id HomEquiv to each other
macro "eqToHom_eq_eqToHom" : tactic =>
  `(tactic|
    apply HomEquiv.trans (by reduce_eqToHom) (by symm; reduce_eqToHom)
  )

lemma HomEquiv.whiskerLeft (X : V) {Y Z} {f f' : Y РЪХ Z} (h : f РЅѕ f') :
    (X РЌЂрхЦ f) РЅѕ (X РЌЂрхЦ f') := by grind

lemma HomEquiv.whiskerRight {X Y} {f f' : X РЪХ Y} (Z : V) (h : f РЅѕ f') :
    (f РќирхЦ Z) РЅѕ (f' РќирхЦ Z) := by grind

lemma HomEquiv.tensorHom_def {XРѓЂ YРѓЂ XРѓѓ YРѓѓ : V} (f : XРѓЂ РЪХрхЦ YРѓЂ) (g : XРѓѓ РЪХрхЦ YРѓѓ) :
    (f РіЌрхЦ g) РЅѕ (f РќирхЦ XРѓѓ РЅФрхЦ YРѓЂ РЌЂрхЦ g) := by grind [tensor_comp_tensor]

lemma HomEquiv.whiskerLeft_id (X Y : V) : (X РЌЂрхЦ (­ЮЪЎ Y)) РЅѕ (­ЮЪЎ (X * Y)) := by
  grind

lemma HomEquiv.id_whiskerRight (X Y : V) : ((­ЮЪЎ X) РќирхЦ Y) РЅѕ (­ЮЪЎ (X * Y)) := by
  grind

instance setoidHom (X Y : V) : Setoid (X РЪХрхЦ Y) :=
РЪеHomEquiv, РЪеHomEquiv.refl, HomEquiv.symm _ _, HomEquiv.transРЪЕРЪЕ
