@[grind]
inductive HomEquiv : Рѕђ {A B : V}, (A РЪХрхЦ B) Рєњ (A РЪХрхЦ B) Рєњ Prop
  | refl (f : X РЪХрхЦ  Y) : HomEquiv f f
  | assoc {W X Y Z : V} (f : W РЪХрхЦ X) (g : X РЪХрхЦ Y) (h : Y РЪХрхЦ Z) :
      HomEquiv ((f РЅФрхЦ g) РЅФрхЦ h) (f РЅФрхЦ (g РЅФрхЦ h))
  | comp_id (f : X РЪХрхЦ Y) : HomEquiv (f РЅФрхЦ (­ЮЪЎрхЦ _)) f
  | id_comp (f : X РЪХрхЦ Y) : HomEquiv ((­ЮЪЎрхЦ _) РЅФрхЦ f) f
  -- congruence
  | comp {f f' : X РЪХрхЦ Y} {g g' : Y РЪХрхЦ Z} :
      HomEquiv f f' Рєњ HomEquiv g g' Рєњ HomEquiv (f РЅФрхЦ g) (f' РЅФрхЦ g')
  | tensor {f f' : W РЪХрхЦ X} {g g' : Y РЪХрхЦ Z} :
      HomEquiv f f' Рєњ HomEquiv g g' Рєњ HomEquiv (f РіЌрхЦ g) (f' РіЌрхЦ g')
  | star {f f' : X РЪХрхЦ Y} :
      HomEquiv f f' Рєњ HomEquiv fРІєрхЦ f'РІєрхЦ
  -- (bi)functoriality
  | id_tensor_id {X Y : V} : HomEquiv ((­ЮЪЎрхЦ X) РіЌрхЦ (­ЮЪЎрхЦ Y)) (­ЮЪЎрхЦ _)
  | tensor_comp_tensor (fРѓЂ : XРѓЂ РЪХрхЦ YРѓЂ) (fРѓѓ : XРѓѓ РЪХрхЦ YРѓѓ)
      (gРѓЂ : YРѓЂ РЪХрхЦ ZРѓЂ) (gРѓѓ : YРѓѓ РЪХрхЦ ZРѓѓ) :
      HomEquiv ((fРѓЂ РіЌрхЦ fРѓѓ) РЅФрхЦ (gРѓЂ РіЌрхЦ gРѓѓ)) ((fРѓЂ РЅФрхЦ gРѓЂ) РіЌрхЦ (fРѓѓ РЅФрхЦ gРѓѓ))
  | star_id {X : V}: HomEquiv (­ЮЪЎрхЦ X)РІєрхЦ (­ЮЪЎрхЦ XРІє)
  | star_comp_star (f : X РЪХрхЦ Y) (g : Y РЪХрхЦ Z) :
      HomEquiv (f РЅФрхЦ g)РІєрхЦ (fРІєрхЦ РЅФрхЦ gРІєрхЦ)
  -- replacing the natural isomorphisms
  | tensor_assoc (f : P РЪХрхЦ Q) (g : W РЪХрхЦ X) (h : Y РЪХрхЦ Z) :
      HomEquiv (((f РіЌрхЦ g) РіЌрхЦ h) РЅФ (eqToHom (mul_assoc Q X Z)))
        ((eqToHom (mul_assoc P W Y)) РЅФрхЦ (f РіЌрхЦ(g РіЌрхЦ h)))
  | id_tensor (f : X РЪХрхЦ Y) :
      HomEquiv (((­ЮЪЎрхЦ 1) РіЌрхЦ f) РЅФрхЦ (eqToHom (one_mul Y))) ((eqToHom (one_mul X)) РЅФ f)
  | tensor_id (f : X РЪХрхЦ Y) :
      HomEquiv ((f РіЌрхЦ (­ЮЪЎрхЦ 1)) РЅФрхЦ (eqToHom (mul_one Y))) ((eqToHom (mul_one X)) РЅФ f)
  | star_skew (f : W РЪХрхЦ X) (g : Y РЪХрхЦ Z) :
      HomEquiv ((fРІєрхЦ РіЌрхЦ gРІєрхЦ) РЅФрхЦ (eqToHom (StarMul.star_mul Z X).symm))
        ((eqToHom (StarMul.star_mul Y W).symm) РЅФ (g РіЌрхЦ f)РІєрхЦ)
  | star_inv (f : X РЪХрхЦ Y) :
      HomEquiv (fРІєрхЦРІєрхЦ РЅФ (eqToHom (star_involutive Y))) ((eqToHom (star_involutive X)) РЅФрхЦ f)
  -- special facts about the twist
  | twist_hom_inv :
      HomEquiv ((¤ѓ_hom X) РЅФрхЦ (¤ѓ_inv X)) (­ЮЪЎрхЦ X)
  | twist_inv_hom :
      HomEquiv ((¤ѓ_inv X) РЅФрхЦ (¤ѓ_hom X)) (­ЮЪЎ XРІє)
  | twist_naturality (f : X РЪХрхЦ Y) :
      HomEquiv (fРІєрхЦ РЅФрхЦ (¤ѓ_inv Y)) ((¤ѓ_inv X) РЅФрхЦ f)
  | tРёЊ (P Q R : V) : HomEquiv
      ((((eqToHom (StarMul.star_mul QРІє PРІє).symm) РЅФ (¤ѓ_inv (QРІє * PРІє))) РіЌрхЦ (­ЮЪЎ RРІєРІє)) РЅФ
        (eqToHom (mul_assoc QРІє PРІє RРІєРІє)) РЅФ ((­ЮЪЎ QРІє) РіЌрхЦ ((eqToHom (StarMul.star_mul RРІє P).symm) РЅФ
        (¤ѓ_inv (RРІє * P)))) РЅФ (eqToHom (mul_assoc QРІє RРІє P).symm) РЅФ
        (((eqToHom (StarMul.star_mul R Q).symm) РЅФ (¤ѓ_inv (R * Q))) РіЌрхЦ (­ЮЪЎ P)) РЅФ
        (eqToHom (mul_assoc R Q P)))
      ((((¤ѓ_inv PРІє) РіЌрхЦ (¤ѓ_inv QРІє)) РіЌрхЦ (¤ѓ_inv RРІє)) РЅФ
        ((eqToHom (StarMul.star_mul Q P).symm) РіЌрхЦ (­ЮЪЎ RРІє)) РЅФ
        (eqToHom (StarMul.star_mul R (Q * P)).symm) РЅФ (¤ѓ_inv (R * (Q * P))))
  -- symm/trans last for constructor tactic
  | symm (f g : X РЪХрхЦ Y) : HomEquiv f g Рєњ HomEquiv g f
  | trans {f g h : X РЪХрхЦ Y} : HomEquiv f g Рєњ HomEquiv g h Рєњ HomEquiv f h

