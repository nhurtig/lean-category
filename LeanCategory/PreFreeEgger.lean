import Mathlib
import LeanCategory.Egger
import LeanCategory.StarMonoid

/- Given a quiver over a monoid, construct the free twisted involutive monoidal category
generated by that quiver -/

variable {V : Type u}

section
variable (V)

-- type synonym: strict twisted monoidal product
@[grind]
structure S where
  val : V

instance : Coe V (S V) where
  coe v := вџЁvвџ©
end

@[ext]
lemma S.ext {x y : S V} : x.val = y.val в†’ x = y := by
  grind

variable [StarMonoid V] [Quiver.{v} V]

inductive Hom : V в†’ V в†’ Type max u v
  | of : (X вџ¶ Y) в†’ Hom X Y -- from the quiver
  | id : (X : V) в†’ Hom X X
  | comp {X Y Z} (f : Hom X Y) (g : Hom Y Z) : Hom X Z
  | tensor {W X Y Z} (f : Hom W Y) (g : Hom X Z) : Hom (W * X) (Y * Z)
  | star {X Y} (f : Hom X Y) : Hom Xв‹† Yв‹†
  | twist_hom (X : V) : Hom X Xв‹†
  | twist_inv (X : V) : Hom Xв‹† X

open CategoryTheory

-- gives us notation
instance : StarMonoid (S V) where
  one := (1 : V)
  mul X Y := X.val * Y.val
  mul_assoc A B C := S.ext <| mul_assoc A.val B.val C.val
  one_mul A := S.ext <| one_mul A.val
  mul_one A := S.ext <| mul_one A.val
  star X := в†‘X.valв‹†
  star_involutive X := S.ext <| star_involutive X.val
  star_mul X Y := S.ext <| StarMul.star_mul X.val Y.val

-- gives us notation
instance (priority := 100) preHom : CategoryStruct (S V) where
  Hom X Y := Hom X.val Y.val
  id X := Hom.id X.val
  comp := Hom.comp

-- synonym for Hom.Tensor that acts on the CategoryStruct notation
def myTensor {W X Y Z : S V} (f : W вџ¶ Y) (g : X вџ¶ Z) : (W * X) вџ¶ (Y * Z) := Hom.tensor f g
infixr:70 " вЉ— " => myTensor

def myStar {X Y : S V} (f : X вџ¶ Y) : Xв‹† вџ¶ Yв‹† := Hom.star f
postfix:max "в‹†" => myStar

def П‚_hom (X : S V) := Hom.twist_hom X.val
def П‚_inv (X : S V) := Hom.twist_inv X.val

-- synonyms to make the monoidal category instance happy (IDK why Mathlib does it this way)
@[simp, grind]
def Hom.whiskerLeft (X : S V) {Yв‚Ѓ Yв‚‚ : S V} (f : Yв‚Ѓ вџ¶ Yв‚‚) : (X * Yв‚Ѓ) вџ¶ (X * Yв‚‚) :=
  (рќџ™ X) вЉ— f

@[simp, grind]
def Hom.whiskerRight {Xв‚Ѓ Xв‚‚ : S V} (f : Xв‚Ѓ вџ¶ Xв‚‚) (Y : S V) : (Xв‚Ѓ * Y) вџ¶ (Xв‚‚ * Y) :=
  f вЉ— (рќџ™ Y)

infixr:81 " в—Ѓ " => Hom.whiskerLeft
infixl:81 " в–· " => Hom.whiskerRight

@[grind]
inductive HomEquiv : в€Ђ {A B : S V}, (A вџ¶ B) в†’ (A вџ¶ B) в†’ Prop
  | refl (f : X вџ¶ Y) : HomEquiv f f
  | assoc (f : W вџ¶ X) (g : X вџ¶ Y) (h : Y вџ¶ Z) :
      HomEquiv ((f в‰« g) в‰« h) (f в‰« (g в‰« h))
  | comp_id (f : X вџ¶ Y) : HomEquiv (f в‰« (рќџ™ _)) f
  | id_comp (f : X вџ¶ Y) : HomEquiv ((рќџ™ _ ) в‰« f) f
  -- congruence
  | comp {f f' : X вџ¶ Y} {g g' : Y вџ¶ Z} :
      HomEquiv f f' в†’ HomEquiv g g' в†’ HomEquiv (f в‰« g) (f' в‰« g')
  | tensor {f f' : W вџ¶ X} {g g' : Y вџ¶ Z} :
      HomEquiv f f' в†’ HomEquiv g g' в†’ HomEquiv (f вЉ— g) (f' вЉ— g')
  | star {f f' : X вџ¶ Y} :
      HomEquiv f f' в†’ HomEquiv fв‹† f'в‹†
  -- (bi)functoriality
  | id_tensor_id {X Y : S V} : HomEquiv ((рќџ™ X) вЉ— (рќџ™ Y)) (рќџ™ _)
  | tensor_comp_tensor (fв‚Ѓ : Xв‚Ѓ вџ¶ Yв‚Ѓ) (fв‚‚ : Xв‚‚ вџ¶ Yв‚‚)
      (gв‚Ѓ : Yв‚Ѓ вџ¶ Zв‚Ѓ) (gв‚‚ : Yв‚‚ вџ¶ Zв‚‚) :
      HomEquiv ((fв‚Ѓ вЉ— fв‚‚) в‰« (gв‚Ѓ вЉ— gв‚‚)) ((fв‚Ѓ в‰« gв‚Ѓ) вЉ— (fв‚‚ в‰« gв‚‚))
  | star_id {X : S V}: HomEquiv (рќџ™ X)в‹† (рќџ™ Xв‹†)
  | star_comp_star (f : X вџ¶ Y) (g : Y вџ¶ Z) :
      HomEquiv (f в‰« g)в‹† (fв‹† в‰« gв‹†)
  -- replacing the natural isomorphisms
  | tensor_assoc (f : P вџ¶ Q) (g : W вџ¶ X) (h : Y вџ¶ Z) :
      HomEquiv (((f вЉ— g) вЉ— h) в‰« (eqToHom (mul_assoc Q X Z)))
        ((eqToHom (mul_assoc P W Y)) в‰« (f вЉ— (g вЉ— h)))
  | id_tensor (f : X вџ¶ Y) :
      HomEquiv (((рќџ™ 1) вЉ— f) в‰« (eqToHom (one_mul Y))) ((eqToHom (one_mul X)) в‰« f)
  | tensor_id (f : X вџ¶ Y) :
      HomEquiv ((f вЉ— (рќџ™ 1)) в‰« (eqToHom (mul_one Y))) ((eqToHom (mul_one X)) в‰« f)
  | star_skew (f : W вџ¶ X) (g : Y вџ¶ Z) :
      HomEquiv ((fв‹† вЉ— gв‹†) в‰« (eqToHom (StarMul.star_mul Z X).symm))
        ((eqToHom (StarMul.star_mul Y W).symm) в‰« (g вЉ— f)в‹†)
  | star_inv (f : X вџ¶ Y) :
      HomEquiv (fв‹†в‹† в‰« (eqToHom (star_involutive Y))) ((eqToHom (star_involutive X)) в‰« f)
  -- special facts about the twist
  | twist_hom_inv :
      HomEquiv ((П‚_hom X) в‰« (П‚_inv X)) (рќџ™ X)
  | twist_inv_hom :
      HomEquiv ((П‚_inv X) в‰« (П‚_hom X)) (рќџ™ Xв‹†)
  | twist_naturality (f : X вџ¶ Y) :
      HomEquiv (fв‹† в‰« (П‚_inv Y)) ((П‚_inv X) в‰« f)
  | tв„“ (P Q R : S V) : HomEquiv
      ((((eqToHom (StarMul.star_mul Qв‹† Pв‹†).symm) в‰« (П‚_inv (Qв‹† * Pв‹†))) вЉ— (рќџ™ Rв‹†в‹†)) в‰«
        (eqToHom (mul_assoc Qв‹† Pв‹† Rв‹†в‹†)) в‰« ((рќџ™ Qв‹†) вЉ— ((eqToHom (StarMul.star_mul Rв‹† P).symm) в‰«
        (П‚_inv (Rв‹† * P)))) в‰« (eqToHom (mul_assoc Qв‹† Rв‹† P).symm) в‰«
        (((eqToHom (StarMul.star_mul R Q).symm) в‰« (П‚_inv (R * Q))) вЉ— (рќџ™ P)) в‰«
        (eqToHom (mul_assoc R Q P)))
      ((((П‚_inv Pв‹†) вЉ— (П‚_inv Qв‹†)) вЉ— (П‚_inv Rв‹†)) в‰«
        ((eqToHom (StarMul.star_mul Q P).symm) вЉ— (рќџ™ Rв‹†)) в‰«
        (eqToHom (StarMul.star_mul R (Q * P)).symm) в‰« (П‚_inv (R * (Q * P))))
  -- symm/trans last for constructor tactic
  | symm (f g : X вџ¶ Y) : HomEquiv f g в†’ HomEquiv g f
  | trans {f g h : X вџ¶ Y} : HomEquiv f g в†’ HomEquiv g h в†’ HomEquiv f h

attribute [refl] HomEquiv.refl
attribute [symm] HomEquiv.symm

instance {A B : S V} : HasEquiv (A вџ¶ B) where
  Equiv := HomEquiv

-- helps grind slog through notation
@[grind =_]
lemma HomEquiv.equiv_def {X Y : S V} {f g : X вџ¶ Y} : HomEquiv f g в†” f в‰€ g := by
  constructor
  all_goals intros h
  all_goals exact h

lemma eqToHom_comp {X Y Z : S V} {f : X вџ¶ Y} {g : Y вџ¶ Z} {p : X = Y} {q : Y = Z} :
    (f в‰€ eqToHom p) в†’ (g в‰€ eqToHom q) в†’ (f в‰« g) в‰€ (eqToHom (p.trans q)) := by
  intros hf hg
  apply HomEquiv.trans
  В· exact HomEquiv.comp hf hg
  В· cases p
    cases q
    simp
    grind

lemma eqToHom_tensor {W X Y Z : S V} {f : W вџ¶ X} {g : Y вџ¶ Z} {p : W = X} {q : Y = Z} :
    (f в‰€ eqToHom p) в†’ (g в‰€ eqToHom q) в†’ (f вЉ— g) в‰€ (eqToHom (by simp [p, q])) := by
  intros hf hg
  apply HomEquiv.trans
  В· exact HomEquiv.tensor hf hg
  cases p
  cases q
  simp
  grind

lemma eqToHom_star {X Y : S V} {f : X вџ¶ Y} {p : X = Y} :
    (f в‰€ eqToHom p) в†’ fв‹† в‰€ (eqToHom (by simp [p])) := by
  intros hf
  apply HomEquiv.trans
  В· exact HomEquiv.star hf
  cases p
  simp
  grind

-- Attempts to take one step of simplifying a bunch of eqToHom/id to one eqToHom
macro "reduce_eqToHom_step" : tactic =>
  `(tactic|
    first
      | apply eqToHom_comp
      | apply eqToHom_tensor
      | apply eqToHom_star
      | rfl
  )

-- shows any combination of eqToHom/id is HomEquiv to a single eqToHom
macro "reduce_eqToHom" : tactic =>
  `(tactic|
    repeat' reduce_eqToHom_step
  )

-- shows any combinations of eqToHom/id HomEquiv to each other
macro "eqToHom_eq_eqToHom" : tactic =>
  `(tactic|
    apply HomEquiv.trans (by reduce_eqToHom) (by symm; reduce_eqToHom)
  )

lemma HomEquiv.whiskerLeft (X : S V) {Y Z} {f f' : Y вџ¶ Z} (h : f в‰€ f') :
    (X в—Ѓ f) в‰€ (X в—Ѓ f') := by grind

lemma HomEquiv.whiskerRight {X Y} {f f' : X вџ¶ Y} (Z : S V) (h : f в‰€ f') :
    (f в–· Z) в‰€ (f' в–· Z) := by grind

lemma HomEquiv.tensorHom_def {Xв‚Ѓ Yв‚Ѓ Xв‚‚ Yв‚‚ : S V} (f : Xв‚Ѓ вџ¶ Yв‚Ѓ) (g : Xв‚‚ вџ¶ Yв‚‚) :
    (f вЉ— g) в‰€ (f в–· Xв‚‚ в‰« Yв‚Ѓ в—Ѓ g) := by grind [tensor_comp_tensor]

lemma HomEquiv.whiskerLeft_id (X Y : S V) : (X в—Ѓ (рќџ™ Y)) в‰€ (рќџ™ (X * Y)) := by
  grind

lemma HomEquiv.id_whiskerRight (X Y : S V) : ((рќџ™ X) в–· Y) в‰€ (рќџ™ (X * Y)) := by
  grind

instance setoidHom (X Y : S V) : Setoid (X вџ¶ Y) :=
вџЁHomEquiv, вџЁHomEquiv.refl, HomEquiv.symm _ _, HomEquiv.transвџ©вџ©
