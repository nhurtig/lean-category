@[simp]
def Hom.inv {X Y : F C} : (X РЪХрхљ Y) Рєњ (Y РЪХрхљ X)
  | id X => id X
  | comp f g => comp (g.inv) (f.inv)
  | whiskerLeft X f => whiskerLeft X (f.inv)
  | whiskerRight f Y => whiskerRight (f.inv) Y
  | tensor f g => tensor (f.inv) (g.inv)
  | ╬▒_hom X Y Z => ╬▒_inv X Y Z
  | ╬▒_inv X Y Z => ╬▒_hom X Y Z
  | l_hom X => l_inv X
  | l_inv X => l_hom X
  | ¤Ђ_hom X => ¤Ђ_inv X
  | ¤Ђ_inv X => ¤Ђ_hom X
  | star f => star (f.inv)
  | ¤Є_hom X Y => ¤Є_inv X Y
  | ¤Є_inv X Y => ¤Є_hom X Y
  | ╬х_hom X => ╬х_inv X
  | ╬х_inv X => ╬х_hom X
  | twist_hom X => twist_inv X
  | twist_inv X => twist_hom X

inductive HomEquiv : Рѕђ {X Y : F C}, (X РЪХрхљ Y) Рєњ (X РЪХрхљ Y) Рєњ Prop
  | refl {X Y} (f : X РЪХрхљ Y) : HomEquiv f f
  | symm {X Y} (f g : X РЪХрхљ Y) : HomEquiv f g Рєњ HomEquiv g f
  | trans {X Y} {f g h : X РЪХрхљ Y} : HomEquiv f g Рєњ HomEquiv g h Рєњ HomEquiv f h
  | comp {X Y Z} {f f' : X РЪХрхљ Y} {g g' : Y РЪХрхљ Z} :
      HomEquiv f f' Рєњ HomEquiv g g' Рєњ HomEquiv (f.comp g) (f'.comp g')
  | whiskerLeft (X) {Y Z} (f f' : Y РЪХрхљ Z) :
      HomEquiv f f' Рєњ HomEquiv (f.whiskerLeft X) (f'.whiskerLeft X)
  | whiskerRight {Y Z} (f f' : Y РЪХрхљ Z) (X) :
      HomEquiv f f' Рєњ HomEquiv (f.whiskerRight X) (f'.whiskerRight X)
  | tensor {W X Y Z} {f f' : W РЪХрхљ X} {g g' : Y РЪХрхљ Z} :
      HomEquiv f f' Рєњ HomEquiv g g' Рєњ HomEquiv (f.tensor g) (f'.tensor g')
  | tensorHom_def {XРѓЂ YРѓЂ XРѓѓ YРѓѓ} (f : XРѓЂ РЪХрхљ YРѓЂ) (g : XРѓѓ РЪХрхљ YРѓѓ) :
      HomEquiv (f.tensor g) ((f.whiskerRight XРѓѓ).comp (g.whiskerLeft YРѓЂ))
  | comp_id {X Y} (f : X РЪХрхљ Y) : HomEquiv (f.comp (Hom.id _)) f
  | id_comp {X Y} (f : X РЪХрхљ Y) : HomEquiv ((Hom.id _).comp f) f
  | assoc {X Y U V : F C} (f : X РЪХрхљ U) (g : U РЪХрхљ V) (h : V РЪХрхљ Y) :
      HomEquiv ((f.comp g).comp h) (f.comp (g.comp h))
  | id_tensorHom_id {X Y} : HomEquiv ((Hom.id X).tensor (Hom.id Y)) (Hom.id _)
  | tensorHom_comp_tensorHom {XРѓЂ YРѓЂ ZРѓЂ XРѓѓ YРѓѓ ZРѓѓ : F C} (fРѓЂ : XРѓЂ РЪХрхљ YРѓЂ) (fРѓѓ : XРѓѓ РЪХрхљ YРѓѓ)
      (gРѓЂ : YРѓЂ РЪХрхљ ZРѓЂ) (gРѓѓ : YРѓѓ РЪХрхљ ZРѓѓ) :
    HomEquiv ((fРѓЂ.tensor fРѓѓ).comp (gРѓЂ.tensor gРѓѓ)) ((fРѓЂ.comp gРѓЂ).tensor (fРѓѓ.comp gРѓѓ))
  | whiskerLeft_id (X Y) : HomEquiv ((Hom.id Y).whiskerLeft X) (Hom.id (X.tensor Y))
  | id_whiskerRight (X Y) : HomEquiv ((Hom.id X).whiskerRight Y) (Hom.id (X.tensor Y))
  | ╬▒_hom_inv {X Y Z} : HomEquiv ((Hom.╬▒_hom X Y Z).comp (Hom.╬▒_inv X Y Z)) (Hom.id _)
  | ╬▒_inv_hom {X Y Z} : HomEquiv ((Hom.╬▒_inv X Y Z).comp (Hom.╬▒_hom X Y Z)) (Hom.id _)
  | associator_naturality {XРѓЂ XРѓѓ XРѓЃ YРѓЂ YРѓѓ YРѓЃ} (fРѓЂ : XРѓЂ РЪХрхљ YРѓЂ) (fРѓѓ : XРѓѓ РЪХрхљ YРѓѓ) (fРѓЃ : XРѓЃ РЪХрхљ YРѓЃ) :
      HomEquiv (((fРѓЂ.tensor fРѓѓ).tensor fРѓЃ).comp (Hom.╬▒_hom YРѓЂ YРѓѓ YРѓЃ))
        ((Hom.╬▒_hom XРѓЂ XРѓѓ XРѓЃ).comp (fРѓЂ.tensor (fРѓѓ.tensor fРѓЃ)))
  | ¤Ђ_hom_inv {X} : HomEquiv ((Hom.¤Ђ_hom X).comp (Hom.¤Ђ_inv X)) (Hom.id _)
  | ¤Ђ_inv_hom {X} : HomEquiv ((Hom.¤Ђ_inv X).comp (Hom.¤Ђ_hom X)) (Hom.id _)
  | ¤Ђ_naturality {X Y} (f : X РЪХрхљ Y) :
      HomEquiv ((f.whiskerRight unit).comp (Hom.¤Ђ_hom Y)) ((Hom.¤Ђ_hom X).comp f)
  | l_hom_inv {X} : HomEquiv ((Hom.l_hom X).comp (Hom.l_inv X)) (Hom.id _)
  | l_inv_hom {X} : HomEquiv ((Hom.l_inv X).comp (Hom.l_hom X)) (Hom.id _)
  | l_naturality {X Y} (f : X РЪХрхљ Y) :
      HomEquiv ((f.whiskerLeft unit).comp (Hom.l_hom Y)) ((Hom.l_hom X).comp f)
  | pentagon {W X Y Z} :
      HomEquiv
        (((Hom.╬▒_hom W X Y).whiskerRight Z).comp
          ((Hom.╬▒_hom W (X.tensor Y) Z).comp ((Hom.╬▒_hom X Y Z).whiskerLeft W)))
        ((Hom.╬▒_hom (W.tensor X) Y Z).comp (Hom.╬▒_hom W X (Y.tensor Z)))
  | triangle {X Y} :
      HomEquiv ((Hom.╬▒_hom X unit Y).comp ((Hom.l_hom Y).whiskerLeft X))
        ((Hom.¤Ђ_hom X).whiskerRight Y)
  -- START OF NAT'S STUFF
  | star {X Y} {f f' : X РЪХрхљ Y} : HomEquiv f f' Рєњ HomEquiv f.star f'.star
  | starHom_id {X} : HomEquiv (Hom.id X).star (Hom.id X.star)
  | starHom_comp_starHom {X Y Z : F C} (f : X РЪХрхљ Y) (g : Y РЪХрхљ Z) :
    HomEquiv (f.comp g).star (f.star.comp g.star)
  | ¤Є_hom_inv {X Y} : HomEquiv ((Hom.¤Є_hom X Y).comp (Hom.¤Є_inv X Y)) (Hom.id _)
  | ¤Є_inv_hom {X Y} : HomEquiv ((Hom.¤Є_inv X Y).comp (Hom.¤Є_hom X Y)) (Hom.id _)
  | ¤Є_naturality {XРѓЂ XРѓѓ YРѓЂ YРѓѓ} (f : XРѓЂ РЪХрхљ YРѓЂ) (g : XРѓѓ РЪХрхљ YРѓѓ) :
    HomEquiv ((f.star.tensor g.star).comp (Hom.¤Є_hom YРѓЂ YРѓѓ))
      ((Hom.¤Є_hom XРѓЂ XРѓѓ).comp (g.tensor f).star)
  | ╬х_hom_inv {X} : HomEquiv ((Hom.╬х_hom X).comp (Hom.╬х_inv X)) (Hom.id _)
  | ╬х_inv_hom {X} : HomEquiv ((Hom.╬х_inv X).comp (Hom.╬х_hom X)) (Hom.id _)
  | ╬х_naturality {X Y : F C} (f : X РЪХрхљ Y) :
    HomEquiv (f.star.star.comp (Hom.╬х_hom Y)) ((Hom.╬х_hom X).comp f)
  | f3 {P Q R : F C} : HomEquiv ((Hom.╬▒_hom P.star Q.star R.star).comp <|
    ((Hom.¤Є_hom Q R).whiskerLeft P.star).comp <|
    (Hom.¤Є_hom P (R * Q)).comp (Hom.╬▒_hom R Q P).star)
    (((Hom.¤Є_hom P Q).whiskerRight R.star).comp (Hom.¤Є_hom (Q * P) R))
  | n2 {P Q : F C} : HomEquiv ((Hom.¤Є_hom P.star Q.star).comp <|
    (Hom.¤Є_hom Q P).star.comp (Hom.╬х_hom (P * Q)))
    ((Hom.╬х_hom P).tensor (Hom.╬х_hom Q))
  | a {R : F C} : HomEquiv (Hom.╬х_hom R).star (Hom.╬х_hom R.star)
  | twist_hom_inv {X} : HomEquiv ((Hom.twist_hom X).comp (Hom.twist_inv X)) (Hom.id _)
  | twist_inv_hom {X} : HomEquiv ((Hom.twist_inv X).comp (Hom.twist_hom X)) (Hom.id _)
  | twist_naturality {X Y : F C} (f : X РЪХрхљ Y) :
    HomEquiv (f.star.comp (Hom.twist_hom Y)) ((Hom.twist_hom X).comp f)
  | tРёЊ {P Q R : F C} : HomEquiv
    (((Hom.¤Є_hom P.star Q.star).whiskerRight R.star.star).comp <|
      ((Hom.twist_hom (Q.star * P.star)).whiskerRight R.star.star).comp <|
      (Hom.╬▒_hom Q.star P.star R.star.star).comp <|
      ((Hom.¤Є_hom P R.star).whiskerLeft Q.star).comp <|
      ((Hom.twist_hom (R.star * P)).whiskerLeft Q.star).comp <|
      (Hom.╬▒_inv Q.star R.star P).comp <|
      ((Hom.¤Є_hom Q R).whiskerRight P).comp <|
      ((Hom.twist_hom (R * Q)).whiskerRight P).comp <|
      (Hom.╬▒_hom R Q P))
    ((((Hom.twist_hom P.star).tensor (Hom.twist_hom Q.star)).tensor (Hom.twist_hom R.star)).comp <|
      ((Hom.¤Є_hom P Q).whiskerRight R.star).comp <|
      (Hom.¤Є_hom (Q * P) R).comp
      (Hom.twist_hom (R * (Q * P))))

def setoidHom (X Y : F C) : Setoid (X РЪХрхљ Y) :=
  РЪеHomEquiv, РЪеHomEquiv.refl, HomEquiv.symm _ _, HomEquiv.transРЪЕРЪЕ

attribute [instance] setoidHom

