import Mathlib
import LeanCategory.Egger
import LeanCategory.StarMonoid

/- Given a quiver over a monoid, construct the free twisted involutive monoidal category
generated by that quiver -/

variable {V : Type u}

section
variable (V)

-- type synonym: strict twisted monoidal product
@[grind]
structure S where
  val : V

instance : Coe V (S V) where
  coe v := РЪеvРЪЕ
end

@[ext]
lemma S.ext {x y : S V} : x.val = y.val Рєњ x = y := by
  grind

variable [StarMonoid V] [Quiver.{v} V]

inductive Hom : V Рєњ V Рєњ Type max u v
  | of : (X РЪХ Y) Рєњ Hom X Y -- from the quiver
  | id : (X : V) Рєњ Hom X X
  | comp {X Y Z} (f : Hom X Y) (g : Hom Y Z) : Hom X Z
  | tensor {W X Y Z} (f : Hom W Y) (g : Hom X Z) : Hom (W * X) (Y * Z)
  | star {X Y} (f : Hom X Y) : Hom XРІє YРІє
  | twist_hom (X : V) : Hom X XРІє
  | twist_inv (X : V) : Hom XРІє X

open CategoryTheory

-- gives us notation
instance : StarMonoid (S V) where
  one := (1 : V)
  mul X Y := X.val * Y.val
  mul_assoc A B C := S.ext <| mul_assoc A.val B.val C.val
  one_mul A := S.ext <| one_mul A.val
  mul_one A := S.ext <| mul_one A.val
  star X := РєЉX.valРІє
  star_involutive X := S.ext <| star_involutive X.val
  star_mul X Y := S.ext <| StarMonoid.star_mul X.val Y.val

-- gives us notation
instance (priority := 100) preHom : CategoryStruct (S V) where
  Hom X Y := Hom X.val Y.val
  id X := Hom.id X.val
  comp := Hom.comp

-- synonym for Hom.Tensor that acts on the CategoryStruct notation
def myTensor {W X Y Z : S V} (f : W РЪХ Y) (g : X РЪХ Z) : (W * X) РЪХ (Y * Z) := Hom.tensor f g
infixr:70 " РіЌ " => myTensor

def myStar {X Y : S V} (f : X РЪХ Y) : XРІє РЪХ YРІє := Hom.star f
postfix:max "РІє" => myStar

def ¤ѓ_hom (X : S V) := Hom.twist_hom X.val
def ¤ѓ_inv (X : S V) := Hom.twist_inv X.val

-- synonyms to make the monoidal category instance happy (IDK why Mathlib does it this way)
@[simp, grind]
def Hom.whiskerLeft (X : S V) {YРѓЂ YРѓѓ : S V} (f : YРѓЂ РЪХ YРѓѓ) : (X * YРѓЂ) РЪХ (X * YРѓѓ) :=
  (­ЮЪЎ X) РіЌ f

@[simp, grind]
def Hom.whiskerRight {XРѓЂ XРѓѓ : S V} (f : XРѓЂ РЪХ XРѓѓ) (Y : S V) : (XРѓЂ * Y) РЪХ (XРѓѓ * Y) :=
  f РіЌ (­ЮЪЎ Y)

infixr:81 " РЌЂ " => Hom.whiskerLeft
infixl:81 " Рќи " => Hom.whiskerRight

@[grind]
inductive HomEquiv : Рѕђ {A B : S V}, (A РЪХ B) Рєњ (A РЪХ B) Рєњ Prop
  | refl (f : X РЪХ Y) : HomEquiv f f
  | assoc (f : W РЪХ X) (g : X РЪХ Y) (h : Y РЪХ Z) :
      HomEquiv ((f РЅФ g) РЅФ h) (f РЅФ (g РЅФ h))
  | comp_id (f : X РЪХ Y) : HomEquiv (f РЅФ (­ЮЪЎ _)) f
  | id_comp (f : X РЪХ Y) : HomEquiv ((­ЮЪЎ _ ) РЅФ f) f
  -- congruence
  | comp {f f' : X РЪХ Y} {g g' : Y РЪХ Z} :
      HomEquiv f f' Рєњ HomEquiv g g' Рєњ HomEquiv (f РЅФ g) (f' РЅФ g')
  | tensor {f f' : W РЪХ X} {g g' : Y РЪХ Z} :
      HomEquiv f f' Рєњ HomEquiv g g' Рєњ HomEquiv (f РіЌ g) (f' РіЌ g')
  | star {f f' : X РЪХ Y} :
      HomEquiv f f' Рєњ HomEquiv fРІє f'РІє
  -- (bi)functoriality
  | id_tensor_id {X Y : S V} : HomEquiv ((­ЮЪЎ X) РіЌ (­ЮЪЎ Y)) (­ЮЪЎ _)
  | tensor_comp_tensor (fРѓЂ : XРѓЂ РЪХ YРѓЂ) (fРѓѓ : XРѓѓ РЪХ YРѓѓ)
      (gРѓЂ : YРѓЂ РЪХ ZРѓЂ) (gРѓѓ : YРѓѓ РЪХ ZРѓѓ) :
      HomEquiv ((fРѓЂ РіЌ fРѓѓ) РЅФ (gРѓЂ РіЌ gРѓѓ)) ((fРѓЂ РЅФ gРѓЂ) РіЌ (fРѓѓ РЅФ gРѓѓ))
  | star_id {X : S V}: HomEquiv (­ЮЪЎ X)РІє (­ЮЪЎ XРІє)
  | star_comp_star (f : X РЪХ Y) (g : Y РЪХ Z) :
      HomEquiv (f РЅФ g)РІє (fРІє РЅФ gРІє)
  -- replacing the natural isomorphisms
  | tensor_assoc (f : P РЪХ Q) (g : W РЪХ X) (h : Y РЪХ Z) :
      HomEquiv (((f РіЌ g) РіЌ h) РЅФ (eqToHom (mul_assoc Q X Z)))
        ((eqToHom (mul_assoc P W Y)) РЅФ (f РіЌ (g РіЌ h)))
  | id_tensor (f : X РЪХ Y) :
      HomEquiv (((­ЮЪЎ 1) РіЌ f) РЅФ (eqToHom (one_mul Y))) ((eqToHom (one_mul X)) РЅФ f)
  | tensor_id (f : X РЪХ Y) :
      HomEquiv ((f РіЌ (­ЮЪЎ 1)) РЅФ (eqToHom (mul_one Y))) ((eqToHom (mul_one X)) РЅФ f)
  | star_skew (f : W РЪХ X) (g : Y РЪХ Z) :
      HomEquiv ((fРІє РіЌ gРІє) РЅФ (eqToHom (StarMonoid.star_mul Z X).symm))
        ((eqToHom (StarMonoid.star_mul Y W).symm) РЅФ (g РіЌ f)РІє)
  | star_inv (f : X РЪХ Y) :
      HomEquiv (fРІєРІє РЅФ (eqToHom (star_involutive Y))) ((eqToHom (star_involutive X)) РЅФ f)
  -- special facts about the twist
  | twist_hom_inv :
      HomEquiv ((¤ѓ_hom X) РЅФ (¤ѓ_inv X)) (­ЮЪЎ X)
  | twist_inv_hom :
      HomEquiv ((¤ѓ_inv X) РЅФ (¤ѓ_hom X)) (­ЮЪЎ XРІє)
  | twist_naturality (f : X РЪХ Y) :
      HomEquiv (fРІє РЅФ (¤ѓ_inv Y)) ((¤ѓ_inv X) РЅФ f)
  | tРёЊ (P Q R : S V) : HomEquiv
      ((((eqToHom (StarMonoid.star_mul QРІє PРІє).symm) РЅФ (¤ѓ_inv (QРІє * PРІє))) РіЌ (­ЮЪЎ RРІєРІє)) РЅФ
        (eqToHom (mul_assoc QРІє PРІє RРІєРІє)) РЅФ ((­ЮЪЎ QРІє) РіЌ ((eqToHom (StarMonoid.star_mul RРІє P).symm) РЅФ
        (¤ѓ_inv (RРІє * P)))) РЅФ (eqToHom (mul_assoc QРІє RРІє P).symm) РЅФ
        (((eqToHom (StarMonoid.star_mul R Q).symm) РЅФ (¤ѓ_inv (R * Q))) РіЌ (­ЮЪЎ P)) РЅФ
        (eqToHom (mul_assoc R Q P)))
      ((((¤ѓ_inv PРІє) РіЌ (¤ѓ_inv QРІє)) РіЌ (¤ѓ_inv RРІє)) РЅФ
        ((eqToHom (StarMonoid.star_mul Q P).symm) РіЌ (­ЮЪЎ RРІє)) РЅФ
        (eqToHom (StarMonoid.star_mul R (Q * P)).symm) РЅФ (¤ѓ_inv (R * (Q * P))))
  -- symm/trans last for constructor tactic
  | symm (f g : X РЪХ Y) : HomEquiv f g Рєњ HomEquiv g f
  | trans {f g h : X РЪХ Y} : HomEquiv f g Рєњ HomEquiv g h Рєњ HomEquiv f h

attribute [refl] HomEquiv.refl
attribute [symm] HomEquiv.symm

instance {A B : S V} : HasEquiv (A РЪХ B) where
  Equiv := HomEquiv

-- helps grind slog through notation
@[grind =_]
lemma HomEquiv.equiv_def {X Y : S V} {f g : X РЪХ Y} : HomEquiv f g Рєћ f РЅѕ g := by
  constructor
  all_goals intros h
  all_goals exact h

lemma eqToHom_comp {X Y Z : S V} {f : X РЪХ Y} {g : Y РЪХ Z} {p : X = Y} {q : Y = Z} :
    (f РЅѕ eqToHom p) Рєњ (g РЅѕ eqToHom q) Рєњ (f РЅФ g) РЅѕ (eqToHom (p.trans q)) := by
  intros hf hg
  apply HomEquiv.trans
  ┬и exact HomEquiv.comp hf hg
  ┬и cases p
    cases q
    simp
    grind

lemma eqToHom_tensor {W X Y Z : S V} {f : W РЪХ X} {g : Y РЪХ Z} {p : W = X} {q : Y = Z} :
    (f РЅѕ eqToHom p) Рєњ (g РЅѕ eqToHom q) Рєњ (f РіЌ g) РЅѕ (eqToHom (by simp [p, q])) := by
  intros hf hg
  apply HomEquiv.trans
  ┬и exact HomEquiv.tensor hf hg
  cases p
  cases q
  simp
  grind

lemma eqToHom_star {X Y : S V} {f : X РЪХ Y} {p : X = Y} :
    (f РЅѕ eqToHom p) Рєњ fРІє РЅѕ (eqToHom (by simp [p])) := by
  intros hf
  apply HomEquiv.trans
  ┬и exact HomEquiv.star hf
  cases p
  simp
  grind

-- Attempts to take one step of simplifying a bunch of eqToHom/id to one eqToHom
macro "reduce_eqToHom_step" : tactic =>
  `(tactic|
    first
      | apply eqToHom_comp
      | apply eqToHom_tensor
      | apply eqToHom_star
      | rfl
  )

-- shows any combination of eqToHom/id is HomEquiv to a single eqToHom
macro "reduce_eqToHom" : tactic =>
  `(tactic|
    repeat' reduce_eqToHom_step
  )

-- shows any combinations of eqToHom/id HomEquiv to each other
macro "eqToHom_eq_eqToHom" : tactic =>
  `(tactic|
    apply HomEquiv.trans (by reduce_eqToHom) (by symm; reduce_eqToHom)
  )

lemma HomEquiv.whiskerLeft (X : S V) {Y Z} {f f' : Y РЪХ Z} (h : f РЅѕ f') :
    (X РЌЂ f) РЅѕ (X РЌЂ f') := by grind

lemma HomEquiv.whiskerRight {X Y} {f f' : X РЪХ Y} (Z : S V) (h : f РЅѕ f') :
    (f Рќи Z) РЅѕ (f' Рќи Z) := by grind

lemma HomEquiv.tensorHom_def {XРѓЂ YРѓЂ XРѓѓ YРѓѓ : S V} (f : XРѓЂ РЪХ YРѓЂ) (g : XРѓѓ РЪХ YРѓѓ) :
    (f РіЌ g) РЅѕ (f Рќи XРѓѓ РЅФ YРѓЂ РЌЂ g) := by grind [tensor_comp_tensor]

lemma HomEquiv.whiskerLeft_id (X Y : S V) : (X РЌЂ (­ЮЪЎ Y)) РЅѕ (­ЮЪЎ (X * Y)) := by
  grind

lemma HomEquiv.id_whiskerRight (X Y : S V) : ((­ЮЪЎ X) Рќи Y) РЅѕ (­ЮЪЎ (X * Y)) := by
  grind

instance setoidHom (X Y : S V) : Setoid (X РЪХ Y) :=
РЪеHomEquiv, РЪеHomEquiv.refl, HomEquiv.symm _ _, HomEquiv.transРЪЕРЪЕ

open HomEquiv

instance : Category (S V) where
  Hom X Y := Quotient (setoidHom X Y)
  id X := РЪд­ЮЪЎ XРЪД
  comp f g := Quotient.mapРѓѓ (┬и РЅФ ┬и) (fun _ _ hf _ _ hg Рєд HomEquiv.comp hf hg) f g
  id_comp {X Y} := by
    rintro РЪеfРЪЕ
    apply Quotient.sound
    grind
  comp_id {X Y} := by
    rintro РЪеfРЪЕ
    apply Quotient.sound
    grind
  assoc {W X Y Z} := by
    rintro РЪеfРЪЕ РЪеgРЪЕ РЪеhРЪЕ
    apply Quotient.sound
    grind

-- not eqToIso! Can't see much hope of generalizing this one
def eqToIso' {X Y : S V} (h : X = Y) : X РЅЁ Y := {
  hom := РЪд@eqToHom _ preHom _ _ hРЪД
  inv := РЪд@eqToHom _ preHom _ _ h.symmРЪД
  hom_inv_id := by
    apply Quotient.sound
    exact eqToHom_comp (by rfl) (by rfl)
  inv_hom_id := by
    apply Quotient.sound
    exact eqToHom_comp (by rfl) (by rfl)
}

-- TODO use ofTensorHom to dodge the nasty whiskers
instance : MonoidalCategory (S V) where
  tensorObj X Y := X * Y
  tensorHom f g := Quotient.mapРѓѓ (┬и РіЌ ┬и) (fun _ _ hf _ _ hg Рєд HomEquiv.tensor hf hg) f g
  tensorUnit := 1
  associator X Y Z := eqToIso' (mul_assoc X Y Z)
  leftUnitor X := eqToIso' (one_mul X)
  rightUnitor X := eqToIso' (mul_one X)
  whiskerLeft X {YРѓЂ YРѓѓ} f := Quotient.map (X РЌЂ ┬и) (fun _ _ hf Рєд HomEquiv.whiskerLeft X hf) f
  whiskerRight {XРѓЂ XРѓѓ} f Y := Quotient.map (┬и Рќи Y) (fun _ _ hf Рєд HomEquiv.whiskerRight Y hf) f
  tensorHom_def {XРѓЂ YРѓЂ XРѓѓ YРѓѓ} := by
    rintro РЪеfРЪЕ РЪеgРЪЕ
    apply Quotient.sound
    apply HomEquiv.tensorHom_def
  id_tensorHom_id _ _ := Quotient.sound id_tensor_id
  tensorHom_comp_tensorHom {XРѓЂ YРѓЂ ZРѓЂ XРѓѓ YРѓѓ ZРѓѓ} := by -- TODO can this be sound?
    rintro РЪеfРѓЂРЪЕ РЪеfРѓѓРЪЕ РЪеgРѓЂРЪЕ РЪеgРѓѓРЪЕ
    apply Quotient.sound
    grind
  whiskerLeft_id X Y := Quotient.sound (HomEquiv.whiskerLeft_id X Y)
  id_whiskerRight X Y := Quotient.sound (HomEquiv.id_whiskerRight X Y)
  associator_naturality {XРѓЂ XРѓѓ XРѓЃ YРѓЂ YРѓѓ YРѓЃ} := by
    rintro РЪеfРѓЂРЪЕ РЪеfРѓѓРЪЕ РЪеfРѓЃРЪЕ
    apply Quotient.sound
    grind
  leftUnitor_naturality {X Y} := by
    rintro РЪеfРЪЕ
    apply Quotient.sound
    grind
  rightUnitor_naturality {X Y} := by
    rintro РЪеfРЪЕ
    apply Quotient.sound
    grind
  pentagon W X Y Z := by
    apply Quotient.sound
    eqToHom_eq_eqToHom
  triangle X Y := by
    apply Quotient.sound
    eqToHom_eq_eqToHom

instance : InvolutiveCategory (S V) where
  starObj X := XРІє
  starHom f := Quotient.map (┬иРІє) (fun _ _ hf Рєд HomEquiv.star hf) f
  skewator X Y := eqToIso' (StarMonoid.star_mul Y X).symm
  involutor X := eqToIso' (star_involutive X)
  starHom_id _ := Quotient.sound star_id
  starHom_comp_starHom {X Y Z} := by
    rintro РЪеfРЪЕ РЪеgРЪЕ
    apply Quotient.sound
    grind
  skewator_naturality {W X Y Z} := by
    rintro РЪеfРЪЕ РЪеgРЪЕ
    apply Quotient.sound
    apply star_skew
  involutor_naturality {X Y} := by
    rintro РЪеfРЪЕ
    apply Quotient.sound
    grind
  f3 X Y Z := by
    apply Quotient.sound
    eqToHom_eq_eqToHom
  n2 X Y := by
    apply Quotient.sound
    eqToHom_eq_eqToHom
  a X := by
    apply Quotient.sound
    eqToHom_eq_eqToHom

instance : TwistedCategory (S V) where
  twist X := {
    hom := РЪд¤ѓ_inv XРЪД
    inv := РЪд¤ѓ_hom XРЪД
    hom_inv_id := by
      apply Quotient.sound
      constructor
    inv_hom_id := by
      apply Quotient.sound
      constructor
  }
  twist_naturality {X Y} := by
    rintro РЪеfРЪЕ
    apply Quotient.sound
    constructor
  tРёЊ X Y Z := by
    apply Quotient.sound
    constructor
