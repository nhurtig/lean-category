  -- | Monoid.tensor x₁ y₁, Monoid.tensor x₂ y₂ => x₁.match x₂ ∧ y₁.match y₂
  -- | _, _ => False

def Monoid.Match.toMonoid : Monoid.Match β X → Monoid β
  | unit => .unit
  | of b => .of b
  | tensor mx my => .tensor mx.toMonoid my.toMonoid

def Monoid.project (f : α → Option β) : Monoid α → Monoid β
  | Monoid.unit => .unit
  | Monoid.of a => match f a with
      | some b => .of b
      | none => .unit
  | Monoid.tensor x y => .tensor (x.project f) (y.project f)

