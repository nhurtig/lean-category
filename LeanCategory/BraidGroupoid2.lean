/-- Formal braids generated by crossings, associators, and unitors. -/
inductive Hom {α : Type u} : Monoid α → Monoid α → Type u
    | id (X : Monoid α) : Hom X X
    | α_hom (X Y Z : Monoid α) : Hom ((X.tensor Y).tensor Z) (X.tensor (Y.tensor Z))
    | α_inv (X Y Z : Monoid α) : Hom (X.tensor (Y.tensor Z)) ((X.tensor Y).tensor Z)
    | l_hom (X) : Hom (Monoid.unit.tensor X) X
    | l_inv (X) : Hom X (Monoid.unit.tensor X)
    | ρ_hom (X) : Hom (X.tensor Monoid.unit) X
    | ρ_inv (X) : Hom X (X.tensor Monoid.unit)
    | σ (X Y : Monoid α) : Hom (X.tensor Y) (Y.tensor X)
    | σ_inv (X Y : Monoid α) : Hom (Y.tensor X) (X.tensor Y)
    | comp {X Y Z} (f : Hom X Y) (g : Hom Y Z) : Hom X Z
    | whiskerLeft (X : Monoid α) {Y₁ Y₂} (f : Hom Y₁ Y₂) : Hom (X.tensor Y₁) (X.tensor Y₂)
    | whiskerRight {X₁ X₂} (f : Hom X₁ X₂) (Y : Monoid α) : Hom (X₁.tensor Y) (X₂.tensor Y)
    | tensor {W X Y Z} (f : Hom W Y) (g : Hom X Z) : Hom (W.tensor X) (Y.tensor Z)

local infixr:10 " ⟶ᵇ " => Hom

def Hom.newMatch {α β : Type u} {X Y : Monoid α} : (X ⟶ᵇ Y) → (X.Match β) → Y.Match β
    | Hom.id _, A => A
    | Hom.α_hom X Y Z, .tensor (.tensor A B) C => .tensor A (.tensor B C)
    | Hom.α_inv X Y Z, .tensor A (.tensor B C) => .tensor (.tensor A B) C
    | Hom.l_hom X, .tensor .unit A => A
    | Hom.l_inv X, A => .tensor .unit A
    | Hom.ρ_hom X, .tensor A .unit => A
    | Hom.ρ_inv X, A => .tensor A .unit
    | Hom.σ X Y, .tensor A B => .tensor B A
    | Hom.σ_inv X Y, .tensor B A => .tensor A B
    | Hom.comp f g, A => Hom.newMatch g (Hom.newMatch f A)
    | Hom.whiskerLeft X f, .tensor A B => .tensor A (Hom.newMatch f B)
    | Hom.whiskerRight f X, .tensor A B => .tensor (Hom.newMatch f A) B
    | Hom.tensor f g, .tensor A B => .tensor (Hom.newMatch f A) (Hom.newMatch g B)

def Hom.newCod {α β : Type u} {X Y : Monoid α} : (X ⟶ᵇ Y) → (X.Match β) → Monoid β
    | f, A => (Hom.newMatch f A).toMonoid

def Hom.enrich : (f : X ⟶ᵇ Y) → (A : X.Match β) → (A.toMonoid ⟶ᵇ f.newCod A)
    | Hom.id X, A => Hom.id (A.toMonoid)
    | Hom.α_hom X Y Z, .tensor (.tensor A B) C => Hom.α_hom A.toMonoid B.toMonoid C.toMonoid
    | Hom.α_inv X Y Z, .tensor A (.tensor B C) => Hom.α_inv A.toMonoid B.toMonoid C.toMonoid
    | Hom.l_hom X, .tensor .unit A => Hom.l_hom A.toMonoid
    | Hom.l_inv X, A => Hom.l_inv A.toMonoid
    | Hom.ρ_hom X, .tensor A .unit => Hom.ρ_hom A.toMonoid
    | Hom.ρ_inv X, A => Hom.ρ_inv A.toMonoid
    | Hom.σ X Y, .tensor A B => Hom.σ A.toMonoid B.toMonoid
    | Hom.σ_inv X Y, .tensor B A => Hom.σ_inv A.toMonoid B.toMonoid
    | Hom.comp f g, A => Hom.comp (Hom.enrich f A) (Hom.enrich g (Hom.newMatch f A))
    | Hom.whiskerLeft X f, .tensor A B => Hom.whiskerLeft A.toMonoid (Hom.enrich f B)
    | Hom.whiskerRight f X, .tensor A B => Hom.whiskerRight (Hom.enrich f A) B.toMonoid
    | Hom.tensor f g, .tensor A B => Hom.tensor (Hom.enrich f A) (Hom.enrich g B)

def Hom.project (map : α → Option β) : (X ⟶ᵇ Y) → (X.project map ⟶ᵇ Y.project map)
  | Hom.id X => Hom.id (X.project map)
  | Hom.α_hom X Y Z => Hom.α_hom (X.project map) (Y.project map) (Z.project map)
  | Hom.α_inv X Y Z => Hom.α_inv (X.project map) (Y.project map) (Z.project map)
  | Hom.l_hom X => Hom.l_hom (X.project map)
  | Hom.l_inv X => Hom.l_inv (X.project map)
  | Hom.ρ_hom X => Hom.ρ_hom (X.project map)
  | Hom.ρ_inv X => Hom.ρ_inv (X.project map)
  | Hom.σ X Y => Hom.σ (X.project map) (Y.project map)
  | Hom.σ_inv X Y => Hom.σ_inv (X.project map) (Y.project map)
  | Hom.comp f g => Hom.comp (f.project map) (g.project map)
  | Hom.whiskerLeft X f => Hom.whiskerLeft (X.project map) (f.project map)
  | Hom.whiskerRight f X => Hom.whiskerRight (f.project map) (X.project map)
  | Hom.tensor f g => Hom.tensor (f.project map) (g.project map)

