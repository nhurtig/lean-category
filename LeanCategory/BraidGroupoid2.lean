inductive Monoid.Match (β : Type u) : Monoid α → Type u
  | unit : Monoid.Match β .unit
  | of : β → Monoid.Match β (.of X)
  | tensor : Monoid.Match β X → Monoid.Match β Y → Monoid.Match β (.tensor X Y)
