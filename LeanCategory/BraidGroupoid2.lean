/-- Objects for the braid groupoid: formal tensors of letters with a unit. -/
-- TODO twisted involutive
inductive Monoid (α : Type u) : Type u
  | of : α → Monoid α
  | unit : Monoid α
  | tensor : Monoid α → Monoid α → Monoid α
  deriving Inhabited, Repr

